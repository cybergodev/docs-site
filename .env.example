# Algolia DocSearch credentials (optional).
#
# If unset, the bundled defaults in docs/.vitepress/config.mts are used, so the
# site builds and works without any configuration. Copy this file to `.env`
# (gitignored) for local overrides, or set the same variables as repository
# secrets in CI to override the search config at build time.
#
# Note: DocSearch apiKey is a public, front-end-visible key by design; moving
# it here just centralizes configuration so it can differ per environment.
VP_ALGOLIA_APP_ID=
VP_ALGOLIA_API_KEY=

# Algolia DocSearch credentials.
#
# REQUIRED for search to work. There are no committed fallbacks: if these are
# unset, Algolia DocSearch is disabled (search box hidden) and the build logs a
# warning. Copy this file to `.env` (gitignored) for local dev, or set the same
# variables as repository secrets in CI / the deploy environment.
#
# The DocSearch apiKey is a public, front-end-visible key by design — safe to
# place in .env; it is not a secret.
VP_ALGOLIA_APP_ID=
VP_ALGOLIA_API_KEY=
